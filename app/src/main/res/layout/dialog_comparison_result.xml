<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 標題區 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="傷口分析對比報告"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#1A237E"
            android:layout_marginBottom="16dp" />

        <!-- 圖片並排比較區 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="視覺對比"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#424242"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 基準圖片 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/comparison_image_border"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="基準"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1976D2"
                            android:gravity="center"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/first_date_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="2024-01-01"
                            android:textSize="11sp"
                            android:textColor="#616161"
                            android:gravity="center"
                            android:paddingBottom="8dp" />

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="160dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="2dp">

                            <ImageView
                                android:id="@+id/first_image"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:contentDescription="基準分析圖" />
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <!-- 箭頭分隔 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textSize="32sp"
                            android:textColor="#FF6F00"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 當前圖片 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/comparison_image_border_current"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="當前"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#388E3C"
                            android:gravity="center"
                            android:paddingBottom="4dp" />

                        <TextView
                            android:id="@+id/second_date_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="2024-01-15"
                            android:textSize="11sp"
                            android:textColor="#616161"
                            android:gravity="center"
                            android:paddingBottom="8dp" />

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="160dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="2dp">

                            <ImageView
                                android:id="@+id/second_image"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:contentDescription="當前分析圖" />
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 數據比較區 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="詳細數據分析"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#424242"
                    android:paddingBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/comparison_data_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="#212121"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 操作提示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提示：可截圖保存此報告，或點擊「匯出報告」功能"
            android:textSize="12sp"
            android:textColor="#757575"
            android:gravity="center"
            android:padding="8dp"
            android:background="#FFF9C4"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>